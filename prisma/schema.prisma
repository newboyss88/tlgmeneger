generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id               String          @id @default(uuid())
  email            String          @unique
  password         String
  name             String
  avatar           String?
  phone            String?
  telegramId       String?
  role             String          @default("ADMIN")
  isBlocked        Boolean         @default(false)
  twoFactorEnabled Boolean         @default(false)
  language         String          @default("uz")
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  auditLogs        AuditLog[]
  bots             Bot[]
  settings         Setting[]
  transactions     Transaction[]
  twoFactorCodes   TwoFactorCode[]
}

model Bot {
  id             String         @id @default(uuid())
  token          String
  username       String?
  name           String?
  avatar         String?
  description    String?
  welcomeMessage String         @default("Assalomu alaykum! Botga xush kelibsiz! 🤖")
  isActive       Boolean        @default(false)
  language       String         @default("uz")
  settings       String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  userId         String
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  groups         Group[]
  telegramUsers  TelegramUser[]
  warehouses     Warehouse[]

  @@index([userId])
}

model TelegramUser {
  id           String        @id @default(uuid())
  telegramId   String
  username     String?
  firstName    String?
  lastName     String?
  isGroup      Boolean       @default(false)
  source       String        @default("BOT")
  isBanned     Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  botId        String
  sessionData  String?
  bot          Bot           @relation(fields: [botId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([botId, telegramId])
  @@index([botId])
}

model Group {
  id           String        @id @default(uuid())
  chatId       String        @unique
  title        String?
  type         String?
  inviteLink   String?
  isActive     Boolean       @default(false)
  autoReply    Boolean       @default(false)
  language     String        @default("uz")
  avatar       String?
  settings     String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  botId        String
  description  String?
  bot          Bot           @relation(fields: [botId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([botId])
}

model Warehouse {
  id          String    @id @default(uuid())
  name        String
  description String?
  location    String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  botId       String
  products    Product[]
  bot         Bot       @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@index([botId])
}

model Product {
  id           String        @id @default(uuid())
  name         String
  sku          String?
  quantity     Int           @default(0)
  price        Float         @default(0)
  unit         String        @default("dona")
  minQuantity  Int           @default(0)
  image        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  warehouseId  String
  warehouse    Warehouse     @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([warehouseId])
}

model Transaction {
  id             String        @id @default(uuid())
  type           String
  quantity       Int
  note           String?
  source         String        @default("MANUAL")
  createdAt      DateTime      @default(now())
  productId      String
  userId         String?
  telegramUserId String?
  groupId        String?
  group          Group?        @relation(fields: [groupId], references: [id])
  telegramUser   TelegramUser? @relation(fields: [telegramUserId], references: [id])
  user           User?         @relation(fields: [userId], references: [id])
  product        Product       @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([userId])
  @@index([telegramUserId])
  @@index([groupId])
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  entity    String
  entityId  String?
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([entity])
}

model Setting {
  id        String   @id @default(uuid())
  key       String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId])
}

model TwoFactorCode {
  id        String   @id @default(uuid())
  code      String
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
